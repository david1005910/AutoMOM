# Database
DATABASE_URL="postgresql://automom:automom@localhost:5432/automom"

# Redis
REDIS_URL="redis://localhost:6379"

# AWS S3
S3_BUCKET="automom-audio"
S3_REGION="ap-northeast-2"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"

# AI APIs
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."

# JWT (RS256 키 쌍 — openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# App
FRONTEND_URL="http://localhost:5173"
PORT=3000
NODE_ENV="development"
COOKIE_SECRET="your-32-char-minimum-secret-here!!"
